{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [
    "@react-banking-security-linter"
  ],
  "rules": {
    "@react-banking-security-linter/navigation-security": "error",
    "@react-banking-security-linter/data-compliance": "error"
  }
}