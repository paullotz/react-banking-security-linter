{
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": 2020,
    "sourceType": "module",
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "plugins": [
    "react-banking-security"
  ],
  "rules": {
    "react-banking-security/navigation-security": "error",
    "react-banking-security/data-compliance": "error"
  }
}